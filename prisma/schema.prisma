// ============================================================
// ERP System - Prisma Schema (PostgreSQL / Supabase)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  HR_MANAGER
  EMPLOYEE
  SALESPERSON
}

enum AccountType {
  ASSET // נכסים
  LIABILITY // התחייבויות
  EQUITY // הון עצמי
  REVENUE // הכנסות
  EXPENSE // הוצאות
}

enum TransactionStatus {
  DRAFT
  POSTED
  VOID
}

enum EmploymentType {
  FULL_TIME // משרה מלאה
  PART_TIME // משרה חלקית
  HOURLY // שעתי
  CONTRACTOR // קבלן
}

enum CustomerStatus {
  LEAD
  ACTIVE
  INACTIVE
  BLOCKED
}

enum CustomerType {
  B2B
  B2C
  GOVERNMENT
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  CHECK
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
}

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
}

enum StockMovementType {
  IN // קניה / קבלת סחורה
  OUT // מכירה / הוצאת סחורה
  TRANSFER // העברה בין מחסנים
  ADJUSTMENT // ספירת מלאי / תיקון
  RETURN_IN // החזרה מלקוח
  RETURN_OUT // החזרה לספק
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum BillStatus {
  DRAFT
  POSTED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum AssetStatus {
  ACTIVE
  DISPOSED
  UNDER_MAINTENANCE
}

enum DepreciationMethod {
  STRAIGHT_LINE // קו ישר
  DECLINING_BALANCE // יתרה פוחתת
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PAID
  REJECTED
}

enum BudgetStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum WebhookStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PosSessionStatus {
  OPEN
  CLOSED
}

enum PosTransactionType {
  SALE
  RETURN
  VOID
}

enum DocumentType {
  QUOTE // הצעת מחיר
  DELIVERY_NOTE // תעודת משלוח
  RECEIPT // קבלה
  PROFORMA // חשבון עסקה (פרופורמה)
  CREDIT_NOTE // הודעת זיכוי
}

enum DocumentStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  CONVERTED // הפך לחשבונית
  CANCELLED
}

// ─────────────────────────────────────────────
// TENANTS (עסקים)
// ─────────────────────────────────────────────

model Tenant {
  id             String  @id @default(cuid())
  name           String
  businessNumber String  @unique // ח.פ. / ע.מ.
  vatNumber      String? @db.VarChar(20) // עוסק מורשה number / מע"מ
  address        Json // { street, city, zip, country }
  phone          String?
  email          String?
  logoUrl        String?

  // הגדרות מס ישראלי
  taxSettings Json @default("{\"vatRate\": 0.18, \"taxYear\": 2025}")
  settings    Json @default("{}")

  // ── SaaS Platform Fields ─────────────────────────────────────
  plan            String    @default("basic") // basic | pro | enterprise
  maxUsers        Int       @default(10)
  maxEmployees    Int       @default(50)
  // which ERP modules are enabled for this tenant
  modules         Json      @default("{\"payroll\":true,\"accounting\":true,\"hr\":true,\"crm\":true,\"inventory\":true,\"pos\":true,\"attendance\":true,\"purchasing\":true,\"assets\":true,\"budget\":true,\"documents\":true}")
  contactName     String? // איש קשר
  notes           String? // הערות פנימיות למנהל הפלטפורמה
  suspendedAt     DateTime?
  suspendedReason String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users               User[]
  employees           Employee[]
  accounts            Account[]
  transactions        Transaction[]
  customers           Customer[]
  attendanceLogs      AttendanceLog[]
  payrollRuns         PayrollRun[]
  invoices            Invoice[]
  leaveTypes          LeaveType[]
  leaveRequests       LeaveRequest[]
  holidayCalendar     HolidayCalendar[]
  activities          Activity[]
  deals               Deal[]
  auditLogs           AuditLog[]
  // New modules
  productCategories   ProductCategory[]
  products            Product[]
  warehouses          Warehouse[]
  stockLevels         StockLevel[]
  stockMovements      StockMovement[]
  vendors             Vendor[]
  purchaseOrders      PurchaseOrder[]
  bills               Bill[]
  fixedAssets         FixedAsset[]
  expenseReports      ExpenseReport[]
  budgets             Budget[]
  webhooks            Webhook[]
  apiKeys             ApiKey[]
  passwordResetTokens PasswordResetToken[]
  posTerminals        PosTerminal[]
  posSessions         PosSession[]
  bankStatements      BankStatement[]
  documents           Document[]
  // HR Extended
  leaveBalances       LeaveBalance[]
  maternityLeaves     MaternityLeave[]
  terminations        Termination[]
  salesOrders         SalesOrder[]
  // Phase 2 modules
  bankAccounts            BankAccount[]
  bankStatementLines      BankStatementLine[]
  paymentBatches          PaymentBatch[]
  goodsReceipts           GoodsReceipt[]
  pettyCashes             PettyCash[]
  pettyCashTransactions   PettyCashTransaction[]
  corporateCreditCards    CorporateCreditCard[]
  creditCardTransactions  CreditCardTransaction[]
  paymentAllocs           PaymentAllocation[]
  trainingCourses         TrainingCourse[]
  employeeTrainings       EmployeeTraining[]
  onboardingTasks         OnboardingTask[]

  @@map("tenants")
}

// ─────────────────────────────────────────────
// PLATFORM ADMIN (בעל הפלטפורמה — מעל כל הטנאנטים)
// ─────────────────────────────────────────────

model PlatformAdmin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("platform_admins")
}

// ─────────────────────────────────────────────
// USERS & RBAC
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  role         UserRole
  firstName    String
  lastName     String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  employee     Employee?
  terminations Termination[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ─────────────────────────────────────────────
// EMPLOYEES (עובדים)
// ─────────────────────────────────────────────

model Employee {
  id       String  @id @default(cuid())
  tenantId String
  userId   String? @unique

  // Personal Info
  firstName     String
  lastName      String
  idNumber      String // ת.ז.
  birthDate     DateTime
  gender        String
  address       Json // { street, city, zip }
  phone         String
  personalEmail String
  bankAccount   Json? // { bank, branch, accountNumber }

  // Employment
  startDate       DateTime
  endDate         DateTime?
  jobTitle        String
  department      String
  employmentType  EmploymentType @default(FULL_TIME)
  directManagerId String?

  // Salary
  grossSalary Decimal  @db.Decimal(12, 2)
  salaryType  String   @default("MONTHLY") // MONTHLY | HOURLY
  hourlyRate  Decimal? @db.Decimal(10, 2)

  // Pension (פנסיה ישראלי - %)
  pensionFund     String?
  pensionEmployee Decimal @default(6.00) @db.Decimal(5, 2) // % עובד
  pensionEmployer Decimal @default(6.50) @db.Decimal(5, 2) // % מעסיק
  severancePay    Decimal @default(8.33) @db.Decimal(5, 2) // % פיצויים
  section14       Boolean @default(true) // סעיף 14 — פיצויים בתוך פנסיה

  // Training Fund — קרן השתלמות (צו הרחבה)
  // 0 = no training fund; standard: employee 2.5%, employer 7.5%
  trainingFundRate   Decimal @default(0) @db.Decimal(5, 2) // % עובד (0 = ללא קרן)
  trainingFundErRate Decimal @default(0) @db.Decimal(5, 2) // % מעסיק

  // Company Car — שווי רכב צמוד (2.48% ממחירון, תקנות 2006)
  carListPrice Decimal? @db.Decimal(12, 2) // מחירון הרכב בשקלים (null = אין רכב)
  carType      String? // REGULAR|HYBRID|PLUGIN_HYBRID|ELECTRIC

  // Tax (מס)
  taxCredits          Decimal @default(2.25) @db.Decimal(5, 2) // נקודות זיכוי כולל
  taxExemptions       Json    @default("[]") // פטורים נוספים
  // פירוט נקודות זיכוי: {resident, gender, children:[{age,points}], veteran, disability, newImmigrant}
  creditPointsDetails Json    @default("{}")

  // Mobile ESS (Employee Self-Service)
  mobilePin String? // PIN 6 ספרות, מוצפן bcrypt — לממשק מובייל

  isActive  Boolean  @default(true)
  metadata  Json     @default("{}") // שדות גמישים
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  user            User?              @relation(fields: [userId], references: [id])
  salaryHistory   SalaryHistory[]
  attendanceLogs  AttendanceLog[]
  payslips        Payslip[]
  leaveRequests   LeaveRequest[]
  expenseReports  ExpenseReport[]
  // HR Extended
  leaveBalances   LeaveBalance[]
  maternityLeaves MaternityLeave[]
  terminations    Termination[]
  trainings       EmployeeTraining[]
  onboardingTasks OnboardingTask[]

  @@unique([tenantId, idNumber])
  @@index([tenantId])
  @@map("employees")
}

model SalaryHistory {
  id          String   @id @default(cuid())
  employeeId  String
  grossSalary Decimal  @db.Decimal(12, 2)
  changedAt   DateTime @default(now())
  changedBy   String // userId
  reason      String?

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("salary_history")
}

// ─────────────────────────────────────────────
// ACCOUNTING - Chart of Accounts (מצב חשבון)
// ─────────────────────────────────────────────

model Account {
  id        String      @id @default(cuid())
  tenantId  String
  code      String // קוד חשבון e.g. "1100"
  name      String // שם בעברית
  nameEn    String? // שם באנגלית
  type      AccountType
  parentId  String?
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  parent         Account?          @relation("AccountHierarchy", fields: [parentId], references: [id])
  children       Account[]         @relation("AccountHierarchy")
  debitLines     TransactionLine[] @relation("DebitAccount")
  creditLines    TransactionLine[] @relation("CreditAccount")
  bankStatements BankStatement[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("accounts")
}

// ─────────────────────────────────────────────
// FINANCIAL TRANSACTIONS (Double-Entry)
// ─────────────────────────────────────────────

model Transaction {
  id          String            @id @default(cuid())
  tenantId    String
  date        DateTime
  reference   String // מספר מסמך מקור
  description String
  status      TransactionStatus @default(DRAFT)

  // מקור הרשומה
  sourceType String // INVOICE | PAYROLL | MANUAL | PAYMENT | EXPENSE
  sourceId   String? // FK לאובייקט המקור

  totalAmount Decimal   @db.Decimal(12, 2)
  currency    String    @default("ILS")
  createdBy   String // userId
  postedAt    DateTime?
  deletedAt   DateTime? // soft-delete
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant            @relation(fields: [tenantId], references: [id])
  lines  TransactionLine[]

  @@index([tenantId, date])
  @@index([tenantId, sourceType, sourceId])
  @@index([tenantId, deletedAt])
  @@map("transactions")
}

// שורות רישום (חובה/זכות)
model TransactionLine {
  id              String  @id @default(cuid())
  transactionId   String
  debitAccountId  String // חשבון חובה
  creditAccountId String // חשבון זכות
  amount          Decimal @db.Decimal(12, 2)
  description     String?
  sortOrder       Int     @default(0)

  // Bank reconciliation
  cleared         Boolean   @default(false)
  clearedAt       DateTime?
  bankStatementId String?

  transaction   Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  debitAccount  Account        @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount Account        @relation("CreditAccount", fields: [creditAccountId], references: [id])
  bankStatement BankStatement? @relation(fields: [bankStatementId], references: [id])

  @@index([bankStatementId])
  @@map("transaction_lines")
}

// ─────────────────────────────────────────────
// PAYROLL (שכר)
// ─────────────────────────────────────────────

model PayrollRun {
  id       String        @id @default(cuid())
  tenantId String
  period   String // "2025-01" (YYYY-MM)
  status   PayrollStatus @default(DRAFT)

  totalGross   Decimal @db.Decimal(12, 2)
  totalNet     Decimal @db.Decimal(12, 2)
  totalTax     Decimal @db.Decimal(12, 2)
  totalNI      Decimal @db.Decimal(12, 2) // ביטוח לאומי
  totalPension Decimal @db.Decimal(12, 2) // סה"כ פנסיה מעסיק

  approvedBy String?
  approvedAt DateTime?
  paidAt     DateTime?
  deletedAt  DateTime? // soft-delete
  createdAt  DateTime  @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  payslips Payslip[]

  @@unique([tenantId, period])
  @@index([tenantId])
  @@map("payroll_runs")
}

model Payslip {
  id           String @id @default(cuid())
  payrollRunId String
  employeeId   String
  tenantId     String
  period       String

  // Gross → Net Breakdown
  grossSalary   Decimal @db.Decimal(12, 2)
  taxableIncome Decimal @db.Decimal(12, 2)

  // הכנסות נוספות
  carBenefit Decimal @default(0) @db.Decimal(12, 2) // שווי רכב צמוד

  // ניכויים עובד
  incomeTax            Decimal @db.Decimal(12, 2) // מס הכנסה
  nationalInsurance    Decimal @db.Decimal(12, 2) // ביטוח לאומי עובד
  healthInsurance      Decimal @db.Decimal(12, 2) // ביטוח בריאות
  pensionEmployee      Decimal @db.Decimal(12, 2) // פנסיה עובד
  trainingFundEmployee Decimal @default(0) @db.Decimal(12, 2) // קרן השתלמות עובד

  netSalary Decimal @db.Decimal(12, 2)

  // עלות מעסיק
  pensionEmployer      Decimal @db.Decimal(12, 2) // פנסיה מעסיק
  severancePay         Decimal @db.Decimal(12, 2) // פיצויים
  niEmployer           Decimal @db.Decimal(12, 2) // ביטוח לאומי מעסיק
  trainingFundEmployer Decimal @default(0) @db.Decimal(12, 2) // קרן השתלמות מעסיק

  totalEmployerCost Decimal @db.Decimal(12, 2)

  // שדות מיוחדים לדיווח טופס 126
  miluimDays      Int @default(0) // ימי מילואים — לדיווח טופס 126
  sickDays        Int @default(0) // ימי מחלה — לדיווח
  unpaidLeaveDays Int @default(0) // ימי חופשה ללא תשלום

  // פירוט מלא ב-JSON
  breakdown Json // { taxBrackets: [...], niCalc: {...} }

  deletedAt DateTime? // soft-delete
  createdAt DateTime  @default(now())

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@unique([payrollRunId, employeeId])
  @@index([tenantId, period])
  @@map("payslips")
}

// ─────────────────────────────────────────────
// CRM - Customers
// ─────────────────────────────────────────────

model Customer {
  id         String         @id @default(cuid())
  tenantId   String
  name       String
  businessId String? // ח.פ. / ת.ז.
  email      String?
  phone      String?
  address    Json?
  type       CustomerType   @default(B2B)
  status     CustomerStatus @default(LEAD)
  assignedTo String? // userId of salesperson

  // JSONB - שדות גמישים לפי סוג לקוח
  metadata Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creditLimit       Decimal?  @db.Decimal(12, 2)
  paymentTermsDays  Int?      // 0=COD, 30=net30, 60=net60

  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  invoices      Invoice[]
  activities    Activity[]
  deals         Deal[]
  documents     Document[]
  salesOrders   SalesOrder[]

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("customers")
}

// ─────────────────────────────────────────────
// ATTENDANCE (נוכחות)
// ─────────────────────────────────────────────

model AttendanceLog {
  id           String    @id @default(cuid())
  tenantId     String
  employeeId   String
  date         DateTime  @db.Date
  clockIn      DateTime
  clockOut     DateTime?
  breakMinutes Int       @default(0)

  // Metadata
  ipAddress   String?
  gpsLocation Json? // { lat, lng }
  deviceInfo  String?
  notes       String?
  approvedBy  String? // userId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, employeeId, date])
  @@map("attendance_logs")
}

// ─────────────────────────────────────────────
// INVOICES (חשבוניות)
// ─────────────────────────────────────────────

model Invoice {
  id                   String        @id @default(cuid())
  tenantId             String
  customerId           String
  number               String // INV-2026-0001 (auto-generated)
  date                 DateTime
  dueDate              DateTime
  status               InvoiceStatus @default(DRAFT)
  subtotal             Decimal       @db.Decimal(12, 2)
  vatAmount            Decimal       @db.Decimal(12, 2)
  total                Decimal       @db.Decimal(12, 2)
  currency             String        @default("ILS")
  discountPercent      Decimal?      @db.Decimal(5, 2) // % הנחה כללית
  discountAmount       Decimal?      @db.Decimal(12, 2) // סכום הנחה כללית
  notes                String?
  paymentTerms         String? // "30 days", "COD", etc.
  reference            String? // מספר הזמנה / אסמכתא
  journalTransactionId String? // FK → auto-created accounting entry

  // Invoice type support
  invoiceType     String  @default("TAX_INVOICE") // TAX_INVOICE | CREDIT_NOTE | RECEIPT | COMMERCIAL
  creditNoteForId String? // Reference to original invoice when this is a credit note

  // Optimistic locking
  version Int @default(0)

  createdBy String
  sentAt    DateTime?
  paidAt    DateTime?
  deletedAt DateTime? // soft-delete
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  customer      Customer            @relation(fields: [customerId], references: [id])
  lines         InvoiceLine[]
  payments      InvoicePayment[]
  creditNoteFor Invoice?            @relation("CreditNotes", fields: [creditNoteForId], references: [id])
  creditNotes   Invoice[]           @relation("CreditNotes")
  paymentAllocs PaymentAllocation[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, deletedAt])
  @@map("invoices")
}

model InvoiceLine {
  id              String  @id @default(cuid())
  invoiceId       String
  productId       String? // optional link to product catalog
  description     String
  sku             String? // מק"ט / קוד פריט
  barcode         String? // ברקוד
  unit            String? // יחידת מידה (יח', ק"ג, שעה, ...)
  quantity        Decimal @db.Decimal(10, 3)
  unitPrice       Decimal @db.Decimal(12, 2)
  discountPercent Decimal @default(0) @db.Decimal(5, 2) // % הנחה לשורה
  discountAmount  Decimal @default(0) @db.Decimal(12, 2) // סכום הנחה לשורה
  vatRate         Decimal @default(0.18) @db.Decimal(5, 4) // 18% מע"מ
  lineTotal       Decimal @db.Decimal(12, 2) // after discount, before VAT
  sortOrder       Int     @default(0)
  notes           String? // הערה לשורה

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation("ProductInvoiceLines", fields: [productId], references: [id])

  @@map("invoice_lines")
}

model InvoicePayment {
  id                   String        @id @default(cuid())
  invoiceId            String
  tenantId             String
  amount               Decimal       @db.Decimal(12, 2)
  method               PaymentMethod
  date                 DateTime
  reference            String? // bank reference / check number
  notes                String?
  journalTransactionId String? // FK → accounting entry
  createdBy            String
  createdAt            DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([tenantId, invoiceId])
  @@map("invoice_payments")
}

// ─────────────────────────────────────────────
// BUSINESS DOCUMENTS (מסמכים עסקיים)
// הצעות מחיר, תעודות משלוח, קבלות, פרופורמות
// ─────────────────────────────────────────────

model Document {
  id              String         @id @default(cuid())
  tenantId        String
  customerId      String?
  type            DocumentType
  status          DocumentStatus @default(DRAFT)
  number          String // QUO-2026-0001, DN-2026-0001, etc.
  date            DateTime
  validUntil      DateTime? // הצעת מחיר — תוקף
  reference       String? // מספר הזמנת לקוח / אסמכתא
  notes           String?
  internalNotes   String? // הערות פנימיות
  subtotal        Decimal        @db.Decimal(12, 2)
  discountPercent Decimal?       @db.Decimal(5, 2)
  discountAmount  Decimal?       @db.Decimal(12, 2)
  vatAmount       Decimal        @db.Decimal(12, 2)
  total           Decimal        @db.Decimal(12, 2)
  currency        String         @default("ILS")

  // Conversion tracking
  convertedToInvoiceId String? // מסמך שהפך לחשבונית
  sourceDocumentId     String? // חשבונית שנוצרה ממסמך זה

  createdBy String
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  customer Customer?      @relation(fields: [customerId], references: [id])
  lines    DocumentLine[]

  @@unique([tenantId, number])
  @@index([tenantId, type, status])
  @@index([tenantId, customerId])
  @@map("documents")
}

model DocumentLine {
  id              String  @id @default(cuid())
  documentId      String
  productId       String?
  description     String
  sku             String?
  barcode         String?
  unit            String?
  quantity        Decimal @db.Decimal(10, 3)
  unitPrice       Decimal @db.Decimal(12, 2)
  discountPercent Decimal @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal @default(0) @db.Decimal(12, 2)
  vatRate         Decimal @default(0.18) @db.Decimal(5, 4)
  lineTotal       Decimal @db.Decimal(12, 2)
  sortOrder       Int     @default(0)
  notes           String?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_lines")
}

// ─────────────────────────────────────────────
// HR - Leave Management (חופשות והיעדרויות)
// ─────────────────────────────────────────────

model LeaveType {
  id               String  @id @default(cuid())
  tenantId         String
  name             String // חופשה שנתית / מחלה / לידה / אבל / מילואים
  isPaid           Boolean @default(true)
  maxDaysPerYear   Int?
  requiresApproval Boolean @default(true)
  colorHex         String  @default("#3B82F6")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("leave_types")
}

model LeaveRequest {
  id             String      @id @default(cuid())
  tenantId       String
  employeeId     String
  leaveTypeId    String
  startDate      DateTime    @db.Date
  endDate        DateTime    @db.Date
  totalDays      Int
  status         LeaveStatus @default(PENDING)
  notes          String?
  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("leave_requests")
}

model HolidayCalendar {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  date       DateTime @db.Date
  isNational Boolean  @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
  @@index([tenantId])
  @@map("holiday_calendar")
}

// ─────────────────────────────────────────────
// HR EXTENDED — Leave Balances, Maternity, Termination
// ─────────────────────────────────────────────

model LeaveBalance {
  id           String   @id @default(cuid())
  tenantId     String
  employeeId   String
  leaveTypeId  String
  year         Int
  accrued      Float    @default(0)
  used         Float    @default(0)
  carryForward Float    @default(0)
  expired      Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@index([tenantId, year])
  @@map("leave_balances")
}

model MaternityLeave {
  id                 String    @id @default(cuid())
  tenantId           String
  employeeId         String
  leaveType          String    @default("MATERNITY") // MATERNITY | PATERNITY
  startDate          DateTime
  expectedEndDate    DateTime
  actualEndDate      DateTime?
  niPaidWeeks        Int       @default(15)
  unpaidWeeks        Int       @default(11)
  jobProtectionUntil DateTime?
  status             String    @default("APPROVED") // APPROVED | ACTIVE | COMPLETED | CANCELLED
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@map("maternity_leaves")
}

model Termination {
  id                String   @id @default(cuid())
  tenantId          String
  employeeId        String
  initiatedById     String
  terminationReason String // RESIGNATION | DISMISSAL_CAUSE | REDUNDANCY | RETIREMENT | MATERNITY_END
  initiatedAt       DateTime @default(now())
  effectiveDate     DateTime
  noticeRequired    Int // days
  noticeEndDate     DateTime
  severanceEligible Boolean  @default(true)
  severanceAmount   Decimal? @db.Decimal(12, 2)
  status            String   @default("NOTICE_ACTIVE") // NOTICE_ACTIVE | COMPLETED | CANCELLED
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  employee    Employee @relation(fields: [employeeId], references: [id])
  initiatedBy User     @relation(fields: [initiatedById], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@map("terminations")
}

// ─────────────────────────────────────────────
// CRM ENHANCEMENT - Activities & Deals
// ─────────────────────────────────────────────

model Activity {
  id          String       @id @default(cuid())
  tenantId    String
  customerId  String
  userId      String // who logged this
  type        ActivityType
  subject     String
  content     String?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([tenantId, customerId])
  @@map("activities")
}

model Deal {
  id                String    @id @default(cuid())
  tenantId          String
  customerId        String
  title             String
  value             Decimal?  @db.Decimal(12, 2)
  currency          String    @default("ILS")
  stage             DealStage @default(LEAD)
  probability       Int       @default(0) // 0-100%
  expectedCloseDate DateTime?
  assignedTo        String? // userId
  notes             String?
  wonAt             DateTime?
  lostAt            DateTime?
  lostReason        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([tenantId, stage])
  @@index([tenantId, customerId])
  @@map("deals")
}

// ─────────────────────────────────────────────
// AUDIT LOG (יומן ביקורת)
// ─────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  tenantId   String
  userId     String?
  action     AuditAction
  entityType String // EMPLOYEE | INVOICE | PAYROLL | USER | CUSTOMER
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ══════════════════════════════════════════════
// PRODUCTS & INVENTORY (מוצרים ומלאי)
// ══════════════════════════════════════════════

model ProductCategory {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  parentId String?

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  @@unique([tenantId, name])
  @@map("product_categories")
}

model Product {
  id            String   @id @default(cuid())
  tenantId      String
  categoryId    String?
  sku           String // מק"ט
  name          String
  description   String?
  unitOfMeasure String   @default("יחידה") // יחידה / ק"ג / מטר...
  costPrice     Decimal  @db.Decimal(12, 2)
  sellingPrice  Decimal  @db.Decimal(12, 2)
  vatRate       Decimal  @default(0.18) @db.Decimal(5, 4)
  isService     Boolean  @default(false) // שירות - אין מלאי
  isActive      Boolean  @default(true)
  barcode       String?
  imageUrl      String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  category       ProductCategory?    @relation(fields: [categoryId], references: [id])
  stockLevels    StockLevel[]
  stockMovements StockMovement[]
  invoiceLines   InvoiceLine[]       @relation("ProductInvoiceLines")
  poLines        PurchaseOrderLine[]
  billLines      BillLine[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("products")
}

model Warehouse {
  id        String  @id @default(cuid())
  tenantId  String
  name      String
  address   Json?
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  stockLevels    StockLevel[]
  stockMovements StockMovement[]

  @@unique([tenantId, name])
  @@map("warehouses")
}

model StockLevel {
  id               String   @id @default(cuid())
  tenantId         String
  productId        String
  warehouseId      String
  quantity         Decimal  @default(0) @db.Decimal(12, 3)
  reservedQuantity Decimal  @default(0) @db.Decimal(12, 3) // locked for orders
  reorderPoint     Decimal? @db.Decimal(12, 3)
  reorderQuantity  Decimal? @db.Decimal(12, 3)
  updatedAt        DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([tenantId])
  @@map("stock_levels")
}

model StockMovement {
  id          String            @id @default(cuid())
  tenantId    String
  productId   String
  warehouseId String
  type        StockMovementType
  quantity    Decimal           @db.Decimal(12, 3)
  unitCost    Decimal?          @db.Decimal(12, 2)
  totalCost   Decimal?          @db.Decimal(12, 2)
  reference   String? // מסמך מקור
  sourceType  String? // INVOICE | PO | ADJUSTMENT
  sourceId    String?
  notes       String?
  createdBy   String
  createdAt   DateTime          @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

// ══════════════════════════════════════════════
// VENDORS & PURCHASING (ספקים ורכש)
// ══════════════════════════════════════════════

model Vendor {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  businessId   String? // ח.פ.
  vatNumber    String?
  email        String?
  phone        String?
  address      Json?
  paymentTerms String? // "30 days"
  status       String   @default("ACTIVE") // ACTIVE | INACTIVE
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bankAccountNumber String?
  bankName          String?
  bankBranch        String?

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  purchaseOrders    PurchaseOrder[]
  bills             Bill[]
  paymentBatchItems PaymentBatchItem[]

  @@index([tenantId])
  @@map("vendors")
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  tenantId     String
  vendorId     String
  number       String // PO-2026-0001
  date         DateTime
  expectedDate DateTime?
  status       PurchaseOrderStatus @default(DRAFT)
  subtotal     Decimal             @db.Decimal(12, 2)
  vatAmount    Decimal             @db.Decimal(12, 2)
  total        Decimal             @db.Decimal(12, 2)
  notes        String?
  createdBy    String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  vendor        Vendor              @relation(fields: [vendorId], references: [id])
  lines         PurchaseOrderLine[]
  bills         Bill[]
  goodsReceipts GoodsReceipt[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id          String  @id @default(cuid())
  poId        String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitCost    Decimal @db.Decimal(12, 2)
  vatRate     Decimal @default(0.18) @db.Decimal(5, 4)
  lineTotal   Decimal @db.Decimal(12, 2)
  receivedQty Decimal @default(0) @db.Decimal(12, 3)
  sortOrder   Int     @default(0)

  po      PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product Product?      @relation(fields: [productId], references: [id])

  @@map("purchase_order_lines")
}

model Bill {
  id                   String     @id @default(cuid())
  tenantId             String
  vendorId             String
  purchaseOrderId      String?
  number               String // BILL-2026-0001
  vendorRef            String? // ספק מספר חשבונית
  date                 DateTime
  dueDate              DateTime
  status               BillStatus @default(DRAFT)
  subtotal             Decimal    @db.Decimal(12, 2)
  vatAmount            Decimal    @db.Decimal(12, 2)
  total                Decimal    @db.Decimal(12, 2)
  notes                String?
  journalTransactionId String?
  createdBy            String
  paidAt               DateTime?
  deletedAt            DateTime? // soft-delete
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  vendor        Vendor         @relation(fields: [vendorId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  lines         BillLine[]
  payments      BillPayment[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@map("bills")
}

model BillLine {
  id          String  @id @default(cuid())
  billId      String
  productId   String?
  accountId   String? // expense account
  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitCost    Decimal @db.Decimal(12, 2)
  vatRate     Decimal @default(0.18) @db.Decimal(5, 4)
  lineTotal   Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  bill    Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("bill_lines")
}

model BillPayment {
  id                   String        @id @default(cuid())
  billId               String
  tenantId             String
  amount               Decimal       @db.Decimal(12, 2)
  method               PaymentMethod
  date                 DateTime
  reference            String?
  notes                String?
  journalTransactionId String?
  createdBy            String
  createdAt            DateTime      @default(now())

  bill Bill @relation(fields: [billId], references: [id])

  @@map("bill_payments")
}

// ══════════════════════════════════════════════
// FIXED ASSETS (רכוש קבוע)
// ══════════════════════════════════════════════

model FixedAsset {
  id                               String             @id @default(cuid())
  tenantId                         String
  code                             String // FA-001
  name                             String
  category                         String // מחשב / רכב / ציוד
  purchaseDate                     DateTime
  purchasePrice                    Decimal            @db.Decimal(12, 2)
  salvageValue                     Decimal            @default(0) @db.Decimal(12, 2)
  usefulLifeYears                  Int
  depreciationMethod               DepreciationMethod @default(STRAIGHT_LINE)
  assetAccountId                   String? // חשבון נכס (2100)
  depreciationExpenseAccountId     String? // הוצאות פחת (7800)
  accumulatedDepreciationAccountId String? // פחת נצבר (2900)
  status                           AssetStatus        @default(ACTIVE)
  disposedAt                       DateTime?
  disposalPrice                    Decimal?           @db.Decimal(12, 2)
  notes                            String?
  createdAt                        DateTime           @default(now())
  updatedAt                        DateTime           @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  depreciationLedger AssetDepreciation[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("fixed_assets")
}

model AssetDepreciation {
  id                   String    @id @default(cuid())
  assetId              String
  tenantId             String
  period               String // "2026-03"
  amount               Decimal   @db.Decimal(12, 2)
  bookValueAfter       Decimal   @db.Decimal(12, 2)
  journalTransactionId String?
  postedAt             DateTime?
  createdAt            DateTime  @default(now())

  asset FixedAsset @relation(fields: [assetId], references: [id])

  @@unique([assetId, period])
  @@map("asset_depreciation")
}

// ══════════════════════════════════════════════
// EXPENSES (הוצאות ודיווחי הוצאות)
// ══════════════════════════════════════════════

model ExpenseReport {
  id             String        @id @default(cuid())
  tenantId       String
  employeeId     String
  title          String
  period         String // "2026-03"
  status         ExpenseStatus @default(DRAFT)
  totalAmount    Decimal       @default(0) @db.Decimal(12, 2)
  notes          String?
  approvedBy     String?
  approvedAt     DateTime?
  paidAt         DateTime?
  rejectedReason String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  employee Employee  @relation(fields: [employeeId], references: [id])
  expenses Expense[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("expense_reports")
}

model Expense {
  id          String   @id @default(cuid())
  reportId    String
  tenantId    String
  date        DateTime
  category    String // נסיעות / ארוחות / ציוד / אחר
  description String
  amount      Decimal  @db.Decimal(12, 2)
  vatAmount   Decimal  @default(0) @db.Decimal(12, 2)
  receiptUrl  String? // Supabase Storage URL
  accountId   String? // expense account FK
  notes       String?

  report ExpenseReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("expenses")
}

// ══════════════════════════════════════════════
// BUDGET (תקציב)
// ══════════════════════════════════════════════

model Budget {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  year        Int
  status      BudgetStatus @default(DRAFT)
  totalBudget Decimal      @default(0) @db.Decimal(14, 2)
  notes       String?
  createdBy   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  lines  BudgetLine[]

  @@unique([tenantId, name, year])
  @@index([tenantId])
  @@map("budgets")
}

model BudgetLine {
  id        String  @id @default(cuid())
  budgetId  String
  accountId String
  amount    Decimal @db.Decimal(12, 2)
  notes     String?

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([budgetId, accountId])
  @@map("budget_lines")
}

// ══════════════════════════════════════════════
// WEBHOOKS & INTEGRATIONS
// ══════════════════════════════════════════════

model Webhook {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  url             String
  secret          String // HMAC secret for signature
  events          Json // ["invoice.created", "payroll.approved", ...]
  isActive        Boolean   @default(true)
  failureCount    Int       @default(0)
  lastDeliveredAt DateTime?
  createdAt       DateTime  @default(now())

  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@map("webhooks")
}

model WebhookDelivery {
  id           String        @id @default(cuid())
  webhookId    String
  event        String
  payload      Json
  status       WebhookStatus @default(PENDING)
  responseCode Int?
  responseBody String?
  duration     Int? // ms
  createdAt    DateTime      @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id])

  @@index([webhookId])
  @@map("webhook_deliveries")
}

// ══════════════════════════════════════════════
// AUTH ENHANCEMENTS
// ══════════════════════════════════════════════

model PasswordResetToken {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([token])
  @@map("password_reset_tokens")
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  keyHash    String    @unique // bcrypt hash of the key
  keyPrefix  String // first 8 chars shown in UI (e.g. "erpk_abc")
  scopes     Json // ["read:invoices", "write:employees"]
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdBy  String
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("api_keys")
}

// ══════════════════════════════════════════════
// POS - POINT OF SALE (קופה)
// ══════════════════════════════════════════════

model PosTerminal {
  id        String   @id @default(cuid())
  tenantId  String
  name      String // "קופה ראשית" / "קופה 2"
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  sessions PosSession[]

  @@index([tenantId])
  @@map("pos_terminals")
}

model PosSession {
  id           String           @id @default(cuid())
  tenantId     String
  terminalId   String
  openedBy     String // userId
  closedBy     String?
  status       PosSessionStatus @default(OPEN)
  openingFloat Decimal          @db.Decimal(12, 2) // מזומן פתיחה
  closingFloat Decimal?         @db.Decimal(12, 2) // מזומן סגירה
  totalSales   Decimal          @default(0) @db.Decimal(12, 2)
  totalReturns Decimal          @default(0) @db.Decimal(12, 2)
  openedAt     DateTime         @default(now())
  closedAt     DateTime?

  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  terminal     PosTerminal      @relation(fields: [terminalId], references: [id])
  transactions PosTransaction[]

  @@index([tenantId])
  @@map("pos_sessions")
}

model PosTransaction {
  id            String             @id @default(cuid())
  tenantId      String
  sessionId     String
  customerId    String?
  type          PosTransactionType @default(SALE)
  subtotal      Decimal            @db.Decimal(12, 2)
  vatAmount     Decimal            @db.Decimal(12, 2)
  total         Decimal            @db.Decimal(12, 2)
  discount      Decimal            @default(0) @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  amountPaid    Decimal            @db.Decimal(12, 2)
  change        Decimal            @default(0) @db.Decimal(12, 2)
  receiptNumber String?
  invoiceId     String? // if receipt was converted to invoice
  notes         String?
  createdAt     DateTime           @default(now())

  session PosSession           @relation(fields: [sessionId], references: [id])
  lines   PosTransactionLine[]

  @@index([tenantId, sessionId])
  @@map("pos_transactions")
}

model PosTransactionLine {
  id            String  @id @default(cuid())
  transactionId String
  productId     String?
  description   String
  quantity      Decimal @db.Decimal(12, 3)
  unitPrice     Decimal @db.Decimal(12, 2)
  discount      Decimal @default(0) @db.Decimal(12, 2)
  vatRate       Decimal @db.Decimal(5, 4)
  lineTotal     Decimal @db.Decimal(12, 2)

  transaction PosTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("pos_transaction_lines")
}

// ─────────────────────────────────────────────
// BANK RECONCILIATION (התאמת בנק)
// ─────────────────────────────────────────────

model BankStatement {
  id             String    @id @default(cuid())
  tenantId       String
  accountId      String // GL bank account (e.g. code 1200)
  period         String // YYYY-MM
  openingBalance Decimal   @default(0) @db.Decimal(15, 2)
  closingBalance Decimal   @default(0) @db.Decimal(15, 2) // balance per bank statement
  status         String    @default("OPEN") // OPEN | RECONCILED
  notes          String?
  createdBy      String
  createdAt      DateTime  @default(now())
  reconciledAt   DateTime?

  tenant  Tenant            @relation(fields: [tenantId], references: [id])
  account Account           @relation(fields: [accountId], references: [id])
  lines   TransactionLine[]

  @@unique([tenantId, accountId, period])
  @@index([tenantId])
  @@map("bank_statements")
}

// ─────────────────────────────────────────────
// SALES ORDERS (הזמנות מכירה)
// ─────────────────────────────────────────────

model SalesOrder {
  id           String    @id @default(cuid())
  tenantId     String
  customerId   String
  quoteId      String?
  number       String
  date         DateTime  @default(now())
  expectedDate DateTime?
  status       String    @default("DRAFT") // DRAFT | CONFIRMED | FULFILLED | CANCELLED
  notes        String?
  subtotal     Decimal   @default(0) @db.Decimal(12, 2)
  vatAmount    Decimal   @default(0) @db.Decimal(12, 2)
  total        Decimal   @default(0) @db.Decimal(12, 2)
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  customer Customer         @relation(fields: [customerId], references: [id])
  lines    SalesOrderLine[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([customerId])
  @@map("sales_orders")
}

model SalesOrderLine {
  id           String  @id @default(cuid())
  salesOrderId String
  productId    String?
  description  String
  quantity     Decimal @db.Decimal(10, 3)
  unitPrice    Decimal @db.Decimal(12, 2)
  vatRate      Decimal @default(0.18) @db.Decimal(5, 4)
  lineTotal    Decimal @db.Decimal(12, 2)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@map("sales_order_lines")
}

// ─── Bank Statement Import ─────────────────────────────────────────
model BankAccount {
  id            String   @id @default(cuid())
  tenantId      String
  bankName      String
  accountNumber String
  branchNumber  String?
  accountName   String?
  currency      String   @default("ILS")
  glAccountId   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  tenant     Tenant              @relation(fields: [tenantId], references: [id])
  statements BankStatementLine[]

  @@unique([tenantId, bankName, accountNumber])
  @@index([tenantId])
}

model BankStatementLine {
  id            String    @id @default(cuid())
  tenantId      String
  bankAccountId String
  date          DateTime
  valueDate     DateTime?
  description   String
  reference     String?
  debit         Decimal?  @db.Decimal(12, 2)
  credit        Decimal?  @db.Decimal(12, 2)
  balance       Decimal?  @db.Decimal(12, 2)
  status        String    @default("UNMATCHED")
  matchedTxId   String?
  importedAt    DateTime  @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([tenantId])
  @@index([date])
}

// ─── Batch Payments ────────────────────────────────────────────────
model PaymentBatch {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  status      String    @default("DRAFT")
  dueDate     DateTime
  totalAmount Decimal   @default(0) @db.Decimal(12, 2)
  itemCount   Int       @default(0)
  exportedAt  DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant             @relation(fields: [tenantId], references: [id])
  items  PaymentBatchItem[]

  @@index([tenantId])
}

model PaymentBatchItem {
  id          String  @id @default(cuid())
  batchId     String
  vendorId    String
  billId      String?
  amount      Decimal @db.Decimal(12, 2)
  bankAccount String?
  bankName    String?
  reference   String?
  status      String  @default("PENDING")

  batch  PaymentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  vendor Vendor       @relation(fields: [vendorId], references: [id])

  @@index([batchId])
}

// ─── Goods Receipt (3-Way Matching) ───────────────────────────────
model GoodsReceipt {
  id              String   @id @default(cuid())
  tenantId        String
  purchaseOrderId String
  number          String
  receivedDate    DateTime @default(now())
  status          String   @default("DRAFT")
  warehouseId     String?
  notes           String?
  createdBy       String
  createdAt       DateTime @default(now())

  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  lines         GoodsReceiptLine[]

  @@unique([tenantId, number])
  @@index([tenantId])
}

model GoodsReceiptLine {
  id             String  @id @default(cuid())
  goodsReceiptId String
  productId      String?
  description    String
  orderedQty     Decimal @db.Decimal(10, 3)
  receivedQty    Decimal @db.Decimal(10, 3)
  unitPrice      Decimal @db.Decimal(12, 2)

  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)

  @@index([goodsReceiptId])
}

// ─── Petty Cash ────────────────────────────────────────────────────
model PettyCash {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  maxBalance  Decimal  @default(500) @db.Decimal(12, 2)
  currency    String   @default("ILS")
  custodianId String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  transactions PettyCashTransaction[]

  @@index([tenantId])
}

model PettyCashTransaction {
  id          String   @id @default(cuid())
  tenantId    String
  pettyCashId String
  type        String
  amount      Decimal  @db.Decimal(12, 2)
  description String
  category    String?
  receiptUrl  String?
  balance     Decimal  @db.Decimal(12, 2)
  glAccountId String?
  createdBy   String
  createdAt   DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  pettyCash PettyCash @relation(fields: [pettyCashId], references: [id])

  @@index([tenantId])
}

// ─── Corporate Credit Cards ────────────────────────────────────────
model CorporateCreditCard {
  id             String   @id @default(cuid())
  tenantId       String
  cardNumber     String
  cardholderName String
  employeeId     String?
  cardType       String
  issuer         String
  creditLimit    Decimal? @db.Decimal(12, 2)
  isActive       Boolean  @default(true)
  glAccountId    String?
  createdAt      DateTime @default(now())

  tenant       Tenant                  @relation(fields: [tenantId], references: [id])
  transactions CreditCardTransaction[]

  @@index([tenantId])
}

model CreditCardTransaction {
  id          String   @id @default(cuid())
  tenantId    String
  cardId      String
  date        DateTime
  description String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("ILS")
  category    String?
  status      String   @default("PENDING")
  expenseId   String?
  importedAt  DateTime @default(now())

  tenant Tenant              @relation(fields: [tenantId], references: [id])
  card   CorporateCreditCard @relation(fields: [cardId], references: [id])

  @@index([tenantId])
}

// ─── Payment Allocation ────────────────────────────────────────────
model PaymentAllocation {
  id          String   @id @default(cuid())
  tenantId    String
  paymentId   String
  invoiceId   String
  amount      Decimal  @db.Decimal(12, 2)
  allocatedAt DateTime @default(now())
  allocatedBy String

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@unique([paymentId, invoiceId])
  @@index([tenantId])
}

// ─── Training & Development ────────────────────────────────────────
model TrainingCourse {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  description    String?
  provider       String?
  durationHours  Int?
  cost           Decimal? @db.Decimal(10, 2)
  isMandatory    Boolean  @default(false)
  validityMonths Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  enrollments EmployeeTraining[]

  @@index([tenantId])
}

model EmployeeTraining {
  id             String    @id @default(cuid())
  tenantId       String
  employeeId     String
  courseId       String
  enrolledAt     DateTime  @default(now())
  completedAt    DateTime?
  expiresAt      DateTime?
  score          Int?
  status         String    @default("ENROLLED")
  notes          String?
  certificateUrl String?

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  employee Employee       @relation(fields: [employeeId], references: [id])
  course   TrainingCourse @relation(fields: [courseId], references: [id])

  @@unique([employeeId, courseId])
  @@index([tenantId])
}

// ─── Onboarding / Offboarding ──────────────────────────────────────
model OnboardingTask {
  id          String    @id @default(cuid())
  tenantId    String
  employeeId  String
  type        String    @default("ONBOARDING")
  title       String
  description String?
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId, employeeId])
}
