{
  "name": "erp-backend",
  "version": "2.0.0",
  "description": "Unified ERP Backend - Node.js + Supabase (PostgreSQL) | Israeli Labor Law 2026",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
